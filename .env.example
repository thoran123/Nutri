PORT=3000
SUPABASE_URL=your_project_url
SUPABASE_KEY=your_anon_key
NODE_ENV=development

# --- Support email (Contact Us) ---------------------------------------------
# Used by utils/emailService.js. If SMTP_HOST/SMTP_USER/SMTP_PASS are unset
# the service falls back to a no-op JSON transport (safe in dev/CI), so the
# Contact Us flow still returns 201 but no email is delivered.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Inbox that receives Contact Us submissions (defaults to SMTP_USER if unset).
SUPPORT_EMAIL=
# Display "From" address (defaults to SUPPORT_EMAIL).
MAIL_FROM=
